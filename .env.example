# Environment Variables - Local Development & Cloud Deployment

# ============================================
# LOCAL DEVELOPMENT SETUP
# ============================================
# For local development with Docker Compose:

# Eureka Server
EUREKA_ENABLED=true
EUREKA_SERVER_URL=http://eureka-server:8761/eureka/

# Microservices Ports (Docker)
PORT_EUREKA=8761
PORT_API_GATEWAY=8080
PORT_USER_SERVICE=8081
PORT_SKILL_ASSESSMENT=8082
PORT_INTERNSHIP_SERVICE=8083
PORT_RECOMMENDATION_SERVICE=8084
PORT_NOTIFICATION_SERVICE=8085

# Database (Local MySQL via Docker)
DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_USERNAME=root
DATABASE_PASSWORD=root

# Profile
SPRING_PROFILES_ACTIVE=docker

# ============================================
# RENDER CLOUD DEPLOYMENT SETUP
# ============================================
# For Render deployments:

# Eureka Server Configuration
SPRING_PROFILES_ACTIVE=prod
EUREKA_HOSTNAME=eureka-server-xxxxxxxxxxxx.onrender.com  # Replace with your Render URL
EUREKA_IP_ADDRESS=                                        # Leave empty (auto-detect)
PORT=8761

# API Gateway Configuration
EUREKA_ENABLED=true
EUREKA_SERVER_URL=https://eureka-server-xxxxxxxxxxxx.onrender.com/eureka/  # Replace URL
PORT=8080

# Microservices Common Configuration
EUREKA_ENABLED=true
EUREKA_SERVER_URL=https://eureka-server-xxxxxxxxxxxx.onrender.com/eureka/  # Replace URL

# User Service
PORT=8081
DATABASE_URL=jdbc:mysql://your-mysql-host:3306/user_service_db?useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true
DATABASE_USERNAME=avnadmin
DATABASE_PASSWORD=your_secure_password_here
DB_POOL_SIZE=10

# Skill Assessment Service
PORT=8082
DATABASE_URL=jdbc:mysql://your-mysql-host:3306/skill_assessment_db?useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true
DATABASE_USERNAME=avnadmin
DATABASE_PASSWORD=your_secure_password_here
DB_POOL_SIZE=10

# Internship Service
PORT=8083
DATABASE_URL=jdbc:mysql://your-mysql-host:3306/internship_service_db?useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true
DATABASE_USERNAME=avnadmin
DATABASE_PASSWORD=your_secure_password_here
DB_POOL_SIZE=10

# Recommendation Service
PORT=8084
# Note: Recommendation service may not need database

# Notification Service
PORT=8085
# Note: Notification service may not need database

# ============================================
# JAVA MEMORY CONFIGURATION
# ============================================
# For Render free tier (512MB RAM limit):
JAVA_TOOL_OPTIONS=-Xmx512m -Xss512k -XX:+UseG1GC

# For production with more memory:
# JAVA_TOOL_OPTIONS=-Xmx2g -Xss512k -XX:+UseG1GC -XX:+UseStringDeduplication

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ALLOWED_ORIGINS=*
# For production, restrict to:
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# SERVICE URLS (If Eureka Disabled)
# ============================================
# Use these if you set EUREKA_ENABLED=false
USER_SERVICE_URL=https://user-service-xxxxxxxxxxxx.onrender.com
SKILL_ASSESSMENT_SERVICE_URL=https://skill-assessment-xxxxxxxxxxxx.onrender.com
INTERNSHIP_SERVICE_URL=https://internship-service-xxxxxxxxxxxx.onrender.com
RECOMMENDATION_SERVICE_URL=https://recommendation-xxxxxxxxxxxx.onrender.com
NOTIFICATION_SERVICE_URL=https://notification-service-xxxxxxxxxxxx.onrender.com

# ============================================
# OPTIONAL: ADDITIONAL CONFIGURATIONS
# ============================================
# JPA Configuration
JPA_DDL_AUTO=validate  # "validate", "update", "create", "create-drop"

# Logging
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_COM_INTERNSHIP=DEBUG

# Eureka Fetch Interval
EUREKA_FETCH_INTERVAL=30  # seconds

# ============================================
# IMPORTANT SECURITY NOTES
# ============================================
# ⚠️  NEVER commit real passwords to git!
# 
# For Render deployments:
# 1. Use Render's "Environment" settings, NOT this file
# 2. For secrets (passwords), use Render's "Secrets" feature
#    - They're masked in logs
#    - Not visible in environment listings
# 
# Steps:
# 1. Delete this file before committing: git rm .env
# 2. In Render Dashboard → Service → Environment
# 3. Add each variable as an environment variable
# 4. For passwords, use "Secrets" instead of "Environment"
#
# Example:
#   ENVIRONMENT: EUREKA_ENABLED=true, PORT=8080
#   SECRETS: DATABASE_PASSWORD=xxx, DATABASE_USERNAME=yyy

# ============================================
# LOCAL TESTING WITH THIS FILE
# ============================================
# To use this file locally:
# 
# 1. Rename to .env:
#    cp .env.example .env
# 
# 2. For Docker Compose, source it:
#    export $(cat .env | xargs)
#    docker-compose up
# 
# 3. For Spring Boot:
#    - Spring Boot reads system environment variables automatically
#    - Or use: spring.config.name=application and SPRING_PROFILES_ACTIVE=dev
